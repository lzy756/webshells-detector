# ============================================================
# WSA (Webshell Agent) 配置文件
# 复制本文件为 .env 后修改，所有变量均以 WSA_ 为前缀
# ============================================================

# ---------- LLM 配置 ----------
# 可选值: anthropic | openai | local
WSA_LLM_PROVIDER=anthropic
WSA_LLM_MODEL=claude-sonnet-4-20250514
WSA_LLM_TEMPERATURE=0.0
WSA_LLM_MAX_TOKENS=4096
WSA_LLM_TIMEOUT_SEC=60
WSA_LLM_RETRY_COUNT=2
# 每个文件允许的 LLM 调用次数上限
WSA_LLM_BUDGET_PER_FILE=1

# 自定义 API 端点（留空则使用官方默认地址）
# 适用于 API 代理、中转站、私有部署等场景
# WSA_LLM_BASE_URL=https://your-proxy.example.com/v1
# 自定义 API Key（留空则从 ANTHROPIC_API_KEY / OPENAI_API_KEY 环境变量读取）
# WSA_LLM_API_KEY=

# ---------- API Keys ----------
# Anthropic (WSA_LLM_PROVIDER=anthropic 时需要)
ANTHROPIC_API_KEY=

# OpenAI (WSA_LLM_PROVIDER=openai 时需要)
# OPENAI_API_KEY=

# 本地模型 Ollama 地址 (WSA_LLM_PROVIDER=local 且未设置 WSA_LLM_BASE_URL 时使用)
# WSA_LOCAL_MODEL_BASE_URL=http://localhost:11434

# ---------- 检测管线 ----------
# 置信度门控阈值
WSA_GATE_HIGH=0.9
WSA_GATE_LOW=0.1
# 是否启用 Docker 沙箱行为分析
WSA_SANDBOX_ENABLED=false

# ---------- 规则路径 ----------
WSA_RULES_DIR=rules
WSA_YARA_DIR=rules/yara
WSA_REGEX_DIR=rules/regex

# ---------- 扫描参数 ----------
WSA_MAX_FILE_SIZE_MB=50
WSA_SCAN_TIMEOUT_SEC=30
WSA_SCAN_WORKERS=4

# ---------- 日志 ----------
# 级别: DEBUG | INFO | WARNING | ERROR
WSA_LOG_LEVEL=INFO
# 格式: json | console
WSA_LOG_FORMAT=console

# ---------- LangSmith 追踪 (可选) ----------
WSA_LANGSMITH_ENABLED=false
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=wsa

# ---------- RAG 配置 (可选) ----------
# 启用 RAG 需先安装: uv sync --extra rag
WSA_RAG_ENABLED=false
WSA_RAG_INDEX_DIR=data
# 嵌入模型: local (sentence-transformers, 离线) | openai (API)
WSA_RAG_EMBEDDING_PROVIDER=local
WSA_RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
WSA_RAG_TOP_K_MALICIOUS=2
WSA_RAG_TOP_K_BENIGN=1
WSA_RAG_SIMILARITY_THRESHOLD=0.3

# ---------- 多 Agent 模式 (可选) ----------
# single: 单 LLM 判断 | multi: 三 Agent 协作 (Commander + Advisor + Validator)
WSA_AGENT_MODE=multi
WSA_AGENT_MAX_LOOPS=3
WSA_AGENT_MAX_LLM_CALLS=8
WSA_AGENT_MAX_TOOL_ROUNDS=5
WSA_AGENT_ENABLE_ADVISOR=true
WSA_AGENT_ENABLE_VALIDATOR=true

# --- Commander (主分析官) ---
# 留空则继承全局 LLM 配置
# WSA_AGENT_COMMANDER_PROVIDER=anthropic
# WSA_AGENT_COMMANDER_MODEL=claude-sonnet-4-20250514
# WSA_AGENT_COMMANDER_BASE_URL=
# WSA_AGENT_COMMANDER_API_KEY=
WSA_AGENT_COMMANDER_TEMPERATURE=0.0
# WSA_AGENT_COMMANDER_MAX_TOKENS=4096

# --- Advisor (提议家) ---
# WSA_AGENT_ADVISOR_PROVIDER=openai
# WSA_AGENT_ADVISOR_MODEL=gpt-4o-mini
# WSA_AGENT_ADVISOR_BASE_URL=
# WSA_AGENT_ADVISOR_API_KEY=
WSA_AGENT_ADVISOR_TEMPERATURE=0.2
# WSA_AGENT_ADVISOR_MAX_TOKENS=4096

# --- Validator (验证官) ---
# WSA_AGENT_VALIDATOR_PROVIDER=anthropic
# WSA_AGENT_VALIDATOR_MODEL=claude-haiku-4-5-20251001
# WSA_AGENT_VALIDATOR_BASE_URL=
# WSA_AGENT_VALIDATOR_API_KEY=
WSA_AGENT_VALIDATOR_TEMPERATURE=0.0
# WSA_AGENT_VALIDATOR_MAX_TOKENS=2048
